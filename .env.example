# Azure DevOps PAT - wiki repo'larini clone etmek icin (build-time)
AZURE_DEVOPS_PAT=

# Microsoft Entra ID (runtime - OAuth2 Proxy)
AZURE_TENANT_ID=122daec4-f1f6-4a14-b85e-5f85417dd9f6
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# OAuth2 Proxy cookie encryption key (32-byte base64)
# Generate: python3 -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
COOKIE_SECRET=
